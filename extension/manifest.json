{
  "manifest_version": 3,
  "name": "LCR Helper",
  "version": "1.2.0.1",
  "description": "A extension with utilities for LCR.",
  "icons": {
    "16": "images/jesus_icon16.png",
    "32": "images/jesus_icon32.png",
    "64": "images/jesus_icon64.png",
    "128": "images/jesus_icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "images/jesus_icon16.png",
      "32": "images/jesus_icon32.png",
      "64": "images/jesus_icon64.png",
      "128": "images/jesus_icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://lcr.churchofjesuschrist.org/mlt/orgs*"
      ],
      "js": [
        "utils.js",
        "common.js",
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "interceptor.js"
      ],
      "matches": [
        "https://lcr.churchofjesuschrist.org/*"
      ]
    }
  ]
}